# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y19 [get_cells m3/clkf_buf]
set_property LOC BUFGCTRL_X0Y16 [get_cells m3/clkout1_buf]
set_property LOC BUFGCTRL_X0Y1 [get_cells m2/m1/clkf_buf]
set_property LOC BUFGCTRL_X0Y0 [get_cells m2/m1/clkout1_buf]
set_property LOC BUFGCTRL_X0Y17 [get_cells m0/m1/clkout1_buf]
set_property LOC BUFGCTRL_X0Y18 [get_cells m0/m1/clkf_buf]

# Location of IO Primitives which is load of clock spine
set_property LOC IOB_X0Y31 [get_cells cmos_xclk_OBUF_inst]

# Location of clock ports
set_property LOC IOB_X0Y24 [get_ports clk]

# Clock net "m3/clk_sdram" driven by instance "m3/clkout1_buf" located at site "BUFGCTRL_X0Y16"
#startgroup
create_pblock {CLKAG_m3/clk_sdram}
add_cells_to_pblock [get_pblocks  {CLKAG_m3/clk_sdram}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="m3/clk_sdram"}]]]
resize_pblock [get_pblocks {CLKAG_m3/clk_sdram}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1}
#endgroup

# Clock net "m2/m1/clk_out" driven by instance "m2/m1/clkout1_buf" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_m2/m1/clk_out}
add_cells_to_pblock [get_pblocks  {CLKAG_m2/m1/clk_out}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL } -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="m2/m1/clk_out"}]]]
resize_pblock [get_pblocks {CLKAG_m2/m1/clk_out}] -add {CLOCKREGION_X0Y1:CLOCKREGION_X0Y1}
#endgroup
